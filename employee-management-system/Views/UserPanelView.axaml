<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
             x:Class="employee_management_system.Views.UserPanelView"
             x:DataType="vm:UserPanelViewModel">

    <Design.DataContext>
        <vm:UserPanelViewModel/>
    </Design.DataContext>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Spacing="16">

            <!-- Card 1: Pracownik + ID zlecenia -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24,16"
                    BoxShadow="0 1 4 0 #22000000">
                <Grid ColumnDefinitions="*,Auto,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Pracownik:"
                                   FontSize="12"
                                   Foreground="#666"/>
                        <TextBlock Text="{Binding EmployeeName}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="18,0">
                        <Button Classes="logout-button"
                                Content="Zmień hasło"
                                Command="{Binding ChangePasswordCommand}"/>
                        <Button Classes="logout-button"
                                Content="Wyloguj"
                                Command="{Binding LogoutCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="ID zlecenia:"
                                   FontSize="12"
                                   Foreground="#666"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding OrderId}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0000FF"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ... existing code ... -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24,20"
                    BoxShadow="0 1 4 0 #22000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Praca:"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111"/>
                    <Border Background="#F8F8F8"
                            CornerRadius="8"
                            Padding="16"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">
                        <TextBlock Text="{Binding CurrentOperation}"
                                   FontSize="18"
                                   Foreground="#333"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card 3: Wybierz operację -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24,20"
                    BoxShadow="0 1 4 0 #22000000">
                <StackPanel Spacing="14">
                    <TextBlock Text="Wybierz zlecenie"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111"/>

                    <ComboBox ItemsSource="{Binding AvailableJobs}"
                              SelectedItem="{Binding SelectedJob}"
                              PlaceholderText="Wybierz zlecenie"
                              IsEnabled="{Binding AreSelectorsEnabled}"
                              HorizontalAlignment="Stretch"
                              Padding="12"/>

                    <TextBlock Text="Wybierz operację"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111"/>

                    <ComboBox ItemsSource="{Binding AvailableOperations}"
                              SelectedItem="{Binding SelectedOperation}"
                              PlaceholderText="Wybierz operację"
                              IsEnabled="{Binding AreSelectorsEnabled}"
                              HorizontalAlignment="Stretch"
                              Padding="12"/>

                    <Grid ColumnDefinitions="*,16,*,16,*">
                        <!-- Rozpocznij -->
                        <Button Grid.Column="0"
                                Classes="success-action-button"
                                Command="{Binding StartOperationCommand}">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="▶" VerticalAlignment="Center"/>
                                <TextBlock Text="Rozpocznj" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Wstrzymaj -->
                        <Button Grid.Column="2"
                                Classes="pause-action-button"
                                Command="{Binding StopOperationCommand}">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="⏸" VerticalAlignment="Center"/>
                                <TextBlock Text="Wstrzymaj" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Zakończ -->
                        <Button Grid.Column="4"
                                Classes="danger-action-button"
                                Command="{Binding RequestEndOperationCommand}">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="⏹" VerticalAlignment="Center"/>
                                <TextBlock Text="Zakończ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
