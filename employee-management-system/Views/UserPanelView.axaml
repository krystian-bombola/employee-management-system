<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
             x:Class="employee_management_system.Views.UserPanelView"
             x:DataType="vm:UserPanelViewModel">

    <Design.DataContext>
        <vm:UserPanelViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- ComboBox style matching project theme -->
        <Style Selector="ComboBox">
            <Style.Resources>
                <SolidColorBrush x:Key="ComboBoxBackground" Color="White"/>
                <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="White"/>
                <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="White"/>

                <SolidColorBrush x:Key="ComboBoxForeground" Color="Black"/>
                <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="Black"/>
                <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="Black"/>
                <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="Black"/>

                <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#999999"/>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#999999"/>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#0000FF"/>
                <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#0000FF"/>

                <SolidColorBrush x:Key="ComboBoxPlaceholderForeground" Color="#888888"/>
                <SolidColorBrush x:Key="ComboBoxPlaceholderForegroundPointerOver" Color="#888888"/>
                <SolidColorBrush x:Key="ComboBoxPlaceholderForegroundFocused" Color="#888888"/>
            </Style.Resources>
        </Style>

        <!-- Logout button (red) -->
        <Style Selector="Button.logout-button">
            <Setter Property="Background" Value="#D94A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.logout-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BD3535"/>
        </Style>
        <Style Selector="Button.logout-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#992A2A"/>
        </Style>

        <!-- ... existing code ... -->
    </UserControl.Styles>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Spacing="16">

            <!-- Card 1: Pracownik + ID zlecenia -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24,16"
                    BoxShadow="0 1 4 0 #22000000">
                <Grid ColumnDefinitions="*,Auto,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Pracownik:"
                                   FontSize="12"
                                   Foreground="#666"/>
                        <TextBlock Text="{Binding EmployeeName}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="18,0">
                        <Button Classes="logout-button"
                                Content="Zmień hasło"
                                Command="{Binding ChangePasswordCommand}"/>
                        <Button Classes="logout-button"
                                Content="Wyloguj"
                                Command="{Binding LogoutCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="ID zlecenia:"
                                   FontSize="12"
                                   Foreground="#666"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding OrderId}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0000FF"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ... existing code ... -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24,20"
                    BoxShadow="0 1 4 0 #22000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Praca:"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111"/>
                    <Border Background="#F8F8F8"
                            CornerRadius="8"
                            Padding="16"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">
                        <TextBlock Text="{Binding CurrentOperation}"
                                   FontSize="18"
                                   Foreground="#333"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card 3: Wybierz operację -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24,20"
                    BoxShadow="0 1 4 0 #22000000">
                <StackPanel Spacing="14">
                    <TextBlock Text="Wybierz zlecenie"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111"/>

                    <ComboBox ItemsSource="{Binding AvailableJobs}"
                              SelectedItem="{Binding SelectedJob}"
                              PlaceholderText="Wybierz zlecenie"
                              IsEnabled="{Binding AreSelectorsEnabled}"
                              HorizontalAlignment="Stretch"
                              Padding="12"/>

                    <TextBlock Text="Wybierz operację"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111"/>

                    <ComboBox ItemsSource="{Binding AvailableOperations}"
                              SelectedItem="{Binding SelectedOperation}"
                              PlaceholderText="Wybierz operację"
                              IsEnabled="{Binding AreSelectorsEnabled}"
                              HorizontalAlignment="Stretch"
                              Padding="12"/>

                    <Grid ColumnDefinitions="*,16,*,16,*">
                        <!-- Rozpocznij -->
                        <Button Grid.Column="0"
                                Command="{Binding StartOperationCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="14"
                                CornerRadius="8"
                                Background="#4AD94A"
                                Foreground="White"
                                FontWeight="SemiBold">

                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background" Value="#4AD94A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#35BD35"/>
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#2A992A"/>
                                </Style>
                                <Style Selector="Button:disabled /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#7FE07F"/>
                                    <Setter Property="TextElement.Foreground" Value="White"/>
                                </Style>
                            </Button.Styles>

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="▶" VerticalAlignment="Center"/>
                                <TextBlock Text="Rozpocznj" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Wstrzymaj -->
                        <Button Grid.Column="2"
                                Command="{Binding StopOperationCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="14"
                                CornerRadius="8"
                                Background="#4A90D9"
                                Foreground="White"
                                FontWeight="SemiBold">

                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background" Value="#4A90D9"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#357ABD"/>
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#2A6099"/>
                                </Style>
                                <Style Selector="Button:disabled /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#7FB3E0"/>
                                    <Setter Property="TextElement.Foreground" Value="White"/>
                                </Style>
                            </Button.Styles>

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="⏸" VerticalAlignment="Center"/>
                                <TextBlock Text="Wstrzymaj" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Zakończ -->
                        <Button Grid.Column="4"
                                Command="{Binding RequestEndOperationCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="14"
                                CornerRadius="8"
                                Background="#D94A4A"
                                Foreground="White"
                                FontWeight="SemiBold">

                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background" Value="#D94A4A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#BD3535"/>
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#992A2A"/>
                                </Style>
                                <Style Selector="Button:disabled /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#E07F7F"/>
                                    <Setter Property="TextElement.Foreground" Value="White"/>
                                </Style>
                            </Button.Styles>

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="⏹" VerticalAlignment="Center"/>
                                <TextBlock Text="Zakończ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            </StackPanel>
        </ScrollViewer>

        <Border IsVisible="{Binding IsEndOperationConfirmationVisible}"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Width="420"
                    Background="White"
                    CornerRadius="12"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 4 16 0 #33000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="Potwierdzenie"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111"/>
                    <TextBlock Text="Czy na pewno operacja została zrealizowana?"
                               TextWrapping="Wrap"
                               Foreground="#333"/>
                    <Grid ColumnDefinitions="*,12,*">
                        <Button Grid.Column="0"
                                Content="Nie"
                                Command="{Binding CancelEndOperationCommand}"
                                Background="#4A90D9"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Padding="12"
                                CornerRadius="8"/>
                        <Button Grid.Column="2"
                                Content="Tak, zakończ"
                                Command="{Binding ConfirmEndOperationCommand}"
                                Background="#D94A4A"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Padding="12"
                                CornerRadius="8"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>

</UserControl>
