<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:employee_management_system.ViewModels"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="500"
        x:Class="employee_management_system.Views.AssignOperationsWindow"
        x:DataType="vm:AssignOperationsViewModel"
        Title="Krok 2: Wybierz operacje"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window assign-operations-window">

    <Border Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Krok 2: Wybierz operacje"
                       FontSize="18" FontWeight="Bold" Foreground="#111"/>
            <TextBlock Text="Wybierz operacje które mają należeć do zlecenia:"
                       Foreground="#555" FontSize="14"/>

            <Border Background="#F9FAFB" CornerRadius="12" Padding="8"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <ListBox Height="350" ItemsSource="{Binding Operations}"
                         Background="Transparent" SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:OperationItemViewModel">
                            <Button Classes="list-select-button"
                                    Command="{Binding ToggleSelectionCommand}"
                                    Padding="10,8">
                                <Grid ColumnDefinitions="40,*">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              IsHitTestVisible="False"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OperationName}"
                                                   FontWeight="SemiBold" FontSize="14" Foreground="#111"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" Classes="logout-button" Content="Anuluj" Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2" Classes="admin-button" Content="Dalej ›" Command="{Binding ConfirmCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
