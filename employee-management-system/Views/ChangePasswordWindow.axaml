<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:employee_management_system.ViewModels"
        x:Class="employee_management_system.Views.ChangePasswordWindow"
        x:DataType="vm:ChangePasswordViewModel"
        Title="Zmiana hasła"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window">

    <Design.DataContext>
        <vm:ChangePasswordViewModel/>
    </Design.DataContext>

    <Border Padding="24">
        <StackPanel Spacing="0">

            <TextBlock Text="Zmiana hasła"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,20"/>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BoxShadow="0 1 4 0 #22000000"
                    Margin="0,0,0,12">
                <StackPanel Spacing="12">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Aktualne hasło" Classes="label"/>
                        <TextBox Text="{Binding CurrentPassword}" Watermark="Aktualne hasło" PasswordChar="●"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nowe hasło" Classes="label"/>
                        <TextBox Text="{Binding NewPassword}" Watermark="Nowe hasło" PasswordChar="●"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Potwierdź nowe hasło" Classes="label"/>
                        <TextBox Text="{Binding ConfirmPassword}" Watermark="Potwierdź nowe hasło" PasswordChar="●"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Komunikat błędu -->
            <Border Background="#FDECEA"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,12"
                    IsVisible="{Binding IsErrorVisible}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#C62828"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </Border>

            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        Classes="secondary-button"
                        Content="Anuluj"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2"
                        Classes="primary-button"
                        Content="Zmień hasło"
                        Command="{Binding SaveCommand}"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>