<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:employee_management_system.ViewModels"
        x:Class="employee_management_system.Views.EditPositionWindow"
        x:DataType="vm:EditPositionViewModel"
        Title="{Binding WindowTitle}"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window">

    <Design.DataContext>
        <vm:EditPositionViewModel/>
    </Design.DataContext>

    <Border Padding="24">
        <StackPanel Spacing="0">

            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,20"/>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BoxShadow="0 1 4 0 #22000000"
                    Margin="0,0,0,16">
                <StackPanel Spacing="12">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nazwa stanowiska" Classes="label"/>
                        <TextBox Name="PositionNameTextBox" Text="{Binding PositionName}" Watermark="Nazwa stanowiska"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Stawka godzinowa (zł)" Classes="label"/>
                        <TextBox Text="{Binding HourlyRate}" Watermark="Stawka godzinowa (zł)"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        Classes="logout-button"
                        Content="Anuluj"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2"
                        Classes="admin-button"
                        Content="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
