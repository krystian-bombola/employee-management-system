<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:employee_management_system.ViewModels"
        x:Class="employee_management_system.Views.ConfirmActionWindow"
        x:DataType="vm:ConfirmActionViewModel"
        Title="{Binding WindowTitle}"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window">

    <Border Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#111"/>
            <TextBlock Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="#333"/>
            <Grid ColumnDefinitions="*,12,*">
                <Button Name="CancelButton"
                        Grid.Column="0"
                        Classes="confirm-cancel"
                        Content="{Binding CancelButtonText}"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2"
                        Classes="confirm-submit"
                        Content="{Binding ConfirmButtonText}"
                        Command="{Binding ConfirmCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
