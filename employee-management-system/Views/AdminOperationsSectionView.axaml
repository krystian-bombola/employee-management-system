<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d"
             x:Class="employee_management_system.Views.AdminOperationsSectionView"
             x:DataType="vm:AdminOperationsSectionViewModel">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
            <TextBlock Grid.Column="0" Text="Operacje" Classes="header" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Watermark="Szukaj po nazwie lub opisie..." Text="{Binding SearchQuery}" Width="300"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="24">
            <StackPanel Grid.Column="0" Spacing="10" VerticalAlignment="Top">
                <TextBlock Text="Nowa Operacja" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                <TextBox Watermark="Nazwa operacji" Text="{Binding NewOperationName}"/>
                <TextBox Watermark="Opis operacji" Text="{Binding NewOperationDescription}"/>
                <Button Classes="admin-button" Content="+ Dodaj operację" Command="{Binding AddOperationCommand}" Margin="0,8,0,0"/>
            </StackPanel>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" Height="500">
                <Grid Grid.Row="0" ColumnDefinitions="50,3*,5*,Auto" Margin="0,0,0,10">
                    <TextBlock Grid.Column="1" Text="Nazwa operacji" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Opis" FontWeight="Bold"/>
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding FilteredOperations}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:OperationItemViewModel">
                            <Grid ColumnDefinitions="50,3*,5*,Auto" Margin="0,10">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding OperationName}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Description}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="3" Content="Usuń" Classes="logout-button" Padding="8,4" FontSize="12"
                                        Command="{Binding $parent[UserControl].((vm:AdminOperationsSectionViewModel)DataContext).RemoveOperationCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>