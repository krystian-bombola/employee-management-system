<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d"
             x:Class="employee_management_system.Views.AdminPositionsSectionView"
             x:DataType="vm:AdminPositionsSectionViewModel">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12" Grid.RowSpan="3">
            <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="Stanowiska" Classes="header" Margin="0" VerticalAlignment="Center"/>
                    <Button Classes="admin-button" Content="+ Dodaj stanowisko" Command="{Binding AddPositionCommand}"/>
                </StackPanel>
                <TextBox Grid.Column="1" Watermark="Szukaj po nazwie stanowiska..." Text="{Binding SearchQuery}" Width="300" Margin="0,0,0,10"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid RowDefinitions="Auto,*" Height="550">
                    <Border Grid.Row="0" Background="#F0F4F8" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,150,90,80">
                            <TextBlock Grid.Column="0" Text="Nazwa stanowiska" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock Grid.Column="1" Text="Stawka godz. (zł)" FontWeight="Bold" Foreground="#333"/>
                        </Grid>
                    </Border>
                    <ListBox Name="PositionsListBox" Grid.Row="1" ItemsSource="{Binding FilteredPositions}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PositionItemViewModel">
                                <Grid ColumnDefinitions="*,150,90,80" Margin="12,10">
                                    <TextBlock Grid.Column="0" Text="{Binding PositionName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="Black"/>
                                    <TextBlock Grid.Column="1" Text="{Binding HourlyRate, StringFormat='{}{0:F2} zł'}" VerticalAlignment="Center" Foreground="Black" FontSize="13"/>
                                    <Button Grid.Column="2" Content="Edytuj" Classes="admin-button" Padding="10,5" FontSize="12" Margin="6,0,6,0" HorizontalAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].((vm:AdminPositionsSectionViewModel)DataContext).EditPositionCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Grid.Column="3" Content="Usuń" Classes="logout-button" Padding="10,5" FontSize="12" HorizontalAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].((vm:AdminPositionsSectionViewModel)DataContext).RemovePositionCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>

    </Grid>
</UserControl>
