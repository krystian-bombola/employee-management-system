<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:employee_management_system.ViewModels"
        x:Class="employee_management_system.Views.EditUserWindow"
        x:DataType="vm:EditUserViewModel"
        Title="Edytuj użytkownika"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F3F4F6">

    <Design.DataContext>
        <vm:EditUserViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBox">
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0000FF"/>
            </Style.Resources>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style Selector="Button.admin-button">
            <Setter Property="Background" Value="#2F6FB7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#255A93"/>
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E4875"/>
        </Style>

        <Style Selector="Button.secondary-button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.secondary-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>
        <Style Selector="Button.secondary-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Styles>

    <Border Padding="24">
        <StackPanel Spacing="0">

            <!-- Nagłówek -->
            <TextBlock Text="Edytuj użytkownika"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,20"/>

            <!-- Karta z formularzem -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BoxShadow="0 1 4 0 #22000000"
                    Margin="0,0,0,16">
                <StackPanel Spacing="12">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Imię" Classes="label"/>
                        <TextBox Text="{Binding FirstName}" Watermark="Imię"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nazwisko" Classes="label"/>
                        <TextBox Text="{Binding LastName}" Watermark="Nazwisko"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="ID / Numer" Classes="label"/>
                        <TextBox Text="{Binding Identifier}" Watermark="ID / Numer"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nowe hasło (pozostaw puste, aby nie zmieniać)" Classes="label"/>
                        <TextBox Text="{Binding NewPassword}" Watermark="Nowe hasło" PasswordChar="●"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Stanowisko" Classes="label"/>
                        <ComboBox PlaceholderText="Wybierz stanowisko"
                                  ItemsSource="{Binding Positions}"
                                  SelectedItem="{Binding SelectedPosition}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PositionItemViewModel">
                                    <TextBlock Text="{Binding PositionName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Przyciski -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        Classes="secondary-button"
                        Content="Anuluj"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2"
                        Classes="admin-button"
                        Content="Zapisz zmiany"
                        Command="{Binding SaveCommand}"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>