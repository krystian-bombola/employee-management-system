<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:employee_management_system.ViewModels"
        x:Class="employee_management_system.Views.EditUserWindow"
        x:DataType="vm:EditUserViewModel"
        Title="{Binding WindowTitle}"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window">

    <Design.DataContext>
        <vm:EditUserViewModel/>
    </Design.DataContext>

    <Border Padding="24">
        <StackPanel Spacing="0">

            <!-- Nagłówek -->
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,20"/>

            <!-- Karta z formularzem -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BoxShadow="0 1 4 0 #22000000"
                    Margin="0,0,0,16">
                <StackPanel Spacing="12">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Imię" Classes="label"/>
                        <TextBox Name="FirstNameTextBox" Text="{Binding FirstName}" Watermark="Imię"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nazwisko" Classes="label"/>
                        <TextBox Text="{Binding LastName}" Watermark="Nazwisko"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="ID / Numer" Classes="label"/>
                        <TextBox Text="{Binding Identifier}" Watermark="ID / Numer"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding PasswordLabel}" Classes="label"/>
                        <TextBox Text="{Binding NewPassword}" Watermark="Hasło" PasswordChar="●"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Stanowisko" Classes="label"/>
                        <ComboBox PlaceholderText="Wybierz stanowisko"
                                  ItemsSource="{Binding Positions}"
                                  SelectedItem="{Binding SelectedPosition}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PositionItemViewModel">
                                    <TextBlock Text="{Binding PositionName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Przyciski -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        Classes="logout-button"
                        Content="Anuluj"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2"
                        Classes="admin-button"
                        Content="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>