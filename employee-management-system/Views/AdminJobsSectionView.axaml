<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d"
             x:Class="employee_management_system.Views.AdminJobsSectionView"
             x:DataType="vm:AdminJobsSectionViewModel">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <!-- Main Content -->
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12" Grid.RowSpan="3">
            <Grid ColumnDefinitions="*,Auto,Auto" Grid.Row="0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="Zlecenia" Classes="header" Margin="0" VerticalAlignment="Center"/>
                    <Button Classes="admin-button" Content="+ Dodaj zlecenie" Command="{Binding AddJobCommand}"/>
                </StackPanel>
                <TextBox Name="SearchTextBox" Grid.Column="1" Watermark="Szukaj po nazwie, opisie lub statusie..." Text="{Binding SearchQuery}" Width="300" Margin="0,0,0,10"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid RowDefinitions="Auto,*" Height="550">
                    <Border Grid.Row="0" Background="#F0F4F8" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="3*,3*,100,130,105,90,80">
                            <TextBlock Grid.Column="0" Text="Nazwa zlecenia" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock Grid.Column="1" Text="Opis" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock Grid.Column="2" Text="Status" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock Grid.Column="3" Text="Data utworzenia" FontWeight="Bold" Foreground="#333"/>
                        </Grid>
                    </Border>
                    <ListBox Name="JobsListBox" Grid.Row="1" 
                             ItemsSource="{Binding FilteredJobs}"
                             SelectedItem="{Binding SelectedJob}">
                        <ListBox.KeyBindings>
                            <KeyBinding Gesture="Delete" Command="{Binding RemoveJobCommand}" CommandParameter="{Binding SelectedJob}"/>
                            <KeyBinding Gesture="Enter" Command="{Binding OpenJobOperationsCommand}" CommandParameter="{Binding SelectedJob}"/>
                        </ListBox.KeyBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:JobItemViewModel">
                                <Grid ColumnDefinitions="3*,3*,100,130,105,90,80" Margin="12,10">
                                    <TextBlock Grid.Column="0" Text="{Binding JobName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="Black" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Description}" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="Black" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}" VerticalAlignment="Center" FontSize="13" Foreground="Black" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" VerticalAlignment="Center" Foreground="Black" FontSize="12"/>
                                    <Button Grid.Column="4" Content="Operacje" Classes="admin-button" Padding="10,5" FontSize="12" Margin="6,0,6,0" Background="#6B7280" HorizontalAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].((vm:AdminJobsSectionViewModel)DataContext).OpenJobOperationsCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Grid.Column="5" Content="Edytuj" Classes="admin-button" Padding="10,5" FontSize="12" Margin="0,0,6,0" HorizontalAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].((vm:AdminJobsSectionViewModel)DataContext).EditJobCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Grid.Column="6" Content="Usuń" Classes="logout-button" Padding="10,5" FontSize="12" HorizontalAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].((vm:AdminJobsSectionViewModel)DataContext).RemoveJobCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>


    </Grid>
</UserControl>
