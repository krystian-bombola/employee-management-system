<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:employee_management_system.ViewModels"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="420"
        x:Class="employee_management_system.Views.AddJobWindow"
        x:DataType="vm:AddJobViewModel"
        Title="{Binding WindowTitle}"
        Width="450" 
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F3F4F6">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="12"/>
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0000FF"/>
            </Style.Resources>
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="Button.admin-button">
            <Setter Property="Background" Value="#2F6FB7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#255A93"/>
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E4875"/>
        </Style>

        <Style Selector="Button.logout-button">
            <Setter Property="Background" Value="#D94A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.logout-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BD3535"/>
        </Style>
        <Style Selector="Button.logout-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#992A2A"/>
        </Style>
    </Window.Styles>

    <Border Padding="24">
        <StackPanel Spacing="0">
            <!-- Header -->
            <TextBlock Text="{Binding HeaderText}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,20"/>

            <!-- Form Card -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BoxShadow="0 1 4 0 #22000000"
                    Margin="0,0,0,24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Nazwa zlecenia" Classes="label"/>
                        <TextBox Name="JobNameTextBox" Text="{Binding JobName}" Watermark="np. Projekt Alpha"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Opis" Classes="label"/>
                        <TextBox Text="{Binding Description}" Watermark="Krótki opis zlecenia..." Height="100" AcceptsReturn="True" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" 
                        Classes="logout-button" 
                        Content="Anuluj" 
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2" 
                        Classes="admin-button" 
                        Content="{Binding ConfirmButtonText}" 
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
