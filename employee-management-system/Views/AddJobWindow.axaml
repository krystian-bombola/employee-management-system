<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:employee_management_system.ViewModels"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="420"
        x:Class="employee_management_system.Views.AddJobWindow"
        x:DataType="vm:AddJobViewModel"
        Title="{Binding WindowTitle}"
        Width="450" 
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window">

    <Border Padding="24">
        <StackPanel Spacing="0">
            <!-- Header -->
            <TextBlock Text="{Binding HeaderText}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,20"/>

            <!-- Form Card -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BoxShadow="0 1 4 0 #22000000"
                    Margin="0,0,0,24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Nazwa zlecenia" Classes="label"/>
                        <TextBox Name="JobNameTextBox" Text="{Binding JobName}" Watermark="np. Projekt Alpha"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Opis" Classes="label"/>
                        <TextBox Text="{Binding Description}" Watermark="Krótki opis zlecenia..." Height="100" AcceptsReturn="True" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" 
                        Classes="logout-button" 
                        Content="Anuluj" 
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2" 
                        Classes="admin-button" 
                        Content="{Binding ConfirmButtonText}" 
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
