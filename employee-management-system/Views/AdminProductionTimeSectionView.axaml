<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d"
             x:Class="employee_management_system.Views.AdminProductionTimeSectionView"
             x:DataType="vm:AdminProductionTimeSectionViewModel">

    <Grid>
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                <TextBlock Grid.Column="0" Text="Czas produkcji" Classes="header" Margin="0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Watermark="Szukaj po nazwie lub statusie..." Text="{Binding SearchQuery}" Width="300" Margin="0,0,0,10"/>
            </Grid>

            <Grid Grid.Row="1" RowDefinitions="Auto,*" Height="460">
                <Border Grid.Row="0" Background="#F0F4F8" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="*,100,120,100,150">
                        <TextBlock Grid.Column="0" Text="Nazwa zlecenia" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Grid.Column="1" Text="Status" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Grid.Column="2" Text="Koszt" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="Czas (h)" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding FilteredJobs}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:JobItemViewModel">
                            <Grid ColumnDefinitions="*,100,120,100,150" Margin="12,10">
                                <TextBlock Grid.Column="0" Text="{Binding JobName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="Black" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center" FontSize="13" Foreground="Black" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="{Binding ComputedCostFormatted}" VerticalAlignment="Center" FontSize="13" Foreground="Black" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding TotalExecutionTimeHours, StringFormat=\{0:F2\}}" VerticalAlignment="Center" FontSize="13" Foreground="Black" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <Button Grid.Column="4" Content="Pokaż szczegóły" Classes="admin-button" Padding="10,5" FontSize="12" Margin="6,0,6,0"
                                        Command="{Binding $parent[UserControl].((vm:AdminProductionTimeSectionViewModel)DataContext).ShowJobDetailsCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
