<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="450"
             x:Class="employee_management_system.Views.AdminWindowView"
             x:DataType="vm:AdminWindowViewModel">

    <Design.DataContext>
        <vm:AdminWindowViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>

                <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>

                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>

                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0000FF"/>
            </Style.Resources>

            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Unified Admin button style -->
        <Style Selector="Button.admin-button">
            <Setter Property="Background" Value="#2F6FB7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#255A93"/>
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E4875"/>
        </Style>
        <Style Selector="Button.admin-button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#8FB8E6"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <!-- Card + headers -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #22000000"/>
        </Style>

        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style Selector="Separator.section">
            <Setter Property="Margin" Value="0,14,0,14"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F3F4F6">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="24"
                  HorizontalAlignment="Stretch"
                  MaxWidth="1440">

                <!-- Make right side fill the remaining space -->
                <Grid ColumnDefinitions="480,24,*">

                    <!-- LEFT -->
                    <Border Grid.Column="0" Classes="card">
                        <StackPanel Spacing="14">

                            <TextBlock Text="Dodawanie operacji" Classes="header"/>
                            <TextBox Watermark="Nazwa operacji"
                                     Text="{Binding NewOperationName, Mode=TwoWay}"/>

                            <Grid ColumnDefinitions="*,10,*">
                                <Button Grid.Column="0"
                                        Classes="admin-button"
                                        Content="+ Dodaj operację"
                                        Command="{Binding AddOperationCommand}"/>
                                <Button Grid.Column="2"
                                        Classes="admin-button"
                                        Content="- Usuń operację"
                                        Command="{Binding RemoveOperationCommand}"/>
                            </Grid>

                            <Separator Classes="section"/>

                            <TextBlock Text="Dodawanie zlecenia" Classes="header"/>
                            <TextBox Watermark="Identyfikator zlecenia"
                                     Text="{Binding NewJobName, Mode=TwoWay}"/>

                            <Grid ColumnDefinitions="*,10,*">
                                <Button Grid.Column="0"
                                        Classes="admin-button"
                                        Content="+ Dodaj zlecenie"
                                        Command="{Binding AddJobCommand}"/>
                                <Button Grid.Column="2"
                                        Classes="admin-button"
                                        Content="- Usuń zlecenie"
                                        Command="{Binding RemoveJobCommand}"/>
                            </Grid>

                            <Separator Classes="section"/>

                            <TextBlock Text="Dodawanie pracownika" Classes="header"/>

                            <Grid ColumnDefinitions="*,10,*,10,*">
                                <TextBox Grid.Column="0"
                                         Watermark="Imię"
                                         Text="{Binding NewUserFirstName, Mode=TwoWay}"/>
                                <TextBox Grid.Column="2"
                                         Watermark="Nazwisko"
                                         Text="{Binding NewUserLastName, Mode=TwoWay}"/>
                                <TextBox Grid.Column="4"
                                         Watermark="Identyfikator"
                                         Text="{Binding NewUserID, Mode=TwoWay}"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,10,*">
                                <Button Grid.Column="0"
                                        Classes="admin-button"
                                        Content="+ Dodaj użytkownika"
                                        Command="{Binding AddUserCommand}"/>
                                <Button Grid.Column="2"
                                        Classes="admin-button"
                                        Content="- Usuń użytkownika"
                                        Command="{Binding RemoveUserCommand}"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- RIGHT (fills the rest of the page up to 1440px) -->
                    <Border Grid.Column="2" Classes="card"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="14">

                            <TextBlock Text="Podgląd czasu produkcji" Classes="header"/>

                            <Border Background="#F8FAFC"
                                    CornerRadius="10"
                                    Padding="12"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">

                                <Grid ColumnDefinitions="2*,2*,2*,2*,2*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Column="0" Text="Pracownik" FontWeight="SemiBold" Foreground="#111" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="Operacja" FontWeight="SemiBold" Foreground="#111" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="2" Text="Czas rozpoczęcia" FontWeight="SemiBold" Foreground="#111" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="3" Text="Czas zakończenia" FontWeight="SemiBold" Foreground="#111" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="4" Text="Czas trwania" FontWeight="SemiBold" Foreground="#111" TextWrapping="Wrap"/>

                                    <Separator Grid.Row="1" Grid.ColumnSpan="5" Margin="0,10,0,0"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Height="360"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ProductionRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProductionRecord">
                                            <Border Background="White"
                                                    CornerRadius="10"
                                                    Padding="12"
                                                    Margin="0,0,0,10"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="1">
                                                <Grid ColumnDefinitions="2*,2*,2*,2*,2*">
                                                    <TextBlock Grid.Column="0" Text="{Binding Employee}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Operation}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding StartTime}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding EndTime}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Duration}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>