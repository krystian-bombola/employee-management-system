<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             xmlns:views="using:employee_management_system.Views"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="450"
             x:Class="employee_management_system.Views.AdminWindowView"
             x:DataType="vm:AdminWindowViewModel">

    <Design.DataContext>
        <vm:AdminWindowViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0000FF"/>
            </Style.Resources>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style Selector="Button.admin-button">
            <Setter Property="Background" Value="#2F6FB7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#255A93"/>
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E4875"/>
        </Style>
        <Style Selector="Button.admin-button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#8FB8E6"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.logout-button">
            <Setter Property="Background" Value="#D94A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.logout-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BD3535"/>
        </Style>
        <Style Selector="Button.logout-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#992A2A"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #22000000"/>
        </Style>

        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Global ListBox Styles -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- ListBoxItem Hover State -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F4F7FA"/>
            <Setter Property="BorderBrush" Value="#D0D9E2"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
        </Style>

        <!-- ListBoxItem Selected State -->
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EAF2FA"/>
            <Setter Property="BorderBrush" Value="#2F6FB7"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
        </Style>


    </UserControl.Styles>

    <Grid Background="#F3F4F6" Margin="24" HorizontalAlignment="Stretch" MaxWidth="1440"
          RowDefinitions="Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="14" Grid.Column="0">
                <Button Classes="admin-button" Content="Użytkownicy" Command="{Binding ShowUsersCommand}" Width="150"/>
                <Button Classes="admin-button" Content="Zlecenia" Command="{Binding ShowJobsCommand}" Width="150"/>
                <Button Classes="admin-button" Content="Czas produkcji" Command="{Binding ShowProductionTimeCommand}" Width="170"/>
                <Button Classes="admin-button" Content="Operacje" Command="{Binding ShowOperationsCommand}" Width="150"/>
                <Button Classes="admin-button" Content="Stanowiska" Command="{Binding ShowPositionsCommand}" Width="150"/>
            </StackPanel>
            <Button Grid.Column="1" Classes="logout-button" Content="Wyloguj" Command="{Binding LogoutCommand}" Width="140"/>
        </Grid>

        <Border Grid.Row="1" Classes="card" Padding="20">
            <Grid>
                <views:AdminUsersSectionView DataContext="{Binding UsersViewModel}" IsVisible="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).IsUsersVisible}" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                <views:AdminOperationsSectionView DataContext="{Binding OperationsViewModel}" IsVisible="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).IsOperationsVisible}" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                <views:AdminJobsSectionView DataContext="{Binding JobsViewModel}" IsVisible="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).IsJobsVisible}" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                <views:AdminPositionsSectionView DataContext="{Binding PositionsViewModel}" IsVisible="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).IsPositionsVisible}" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                <views:AdminProductionTimeSectionView DataContext="{Binding ProductionTimeViewModel}" IsVisible="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).IsProductionTimeVisible}" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>