<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:employee_management_system.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="450"
             x:Class="employee_management_system.Views.AdminWindowView"
             x:DataType="vm:AdminWindowViewModel">

    <Design.DataContext>
        <vm:AdminWindowViewModel/>
    </Design.DataContext>


    <UserControl.Styles>
        <Style Selector="TextBox">
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>

                <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>

                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>

                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#999999"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0000FF"/>
            </Style.Resources>

            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style Selector="Button.admin-button">
            <Setter Property="Background" Value="#2F6FB7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#255A93"/>
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E4875"/>
        </Style>
        <Style Selector="Button.admin-button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#8FB8E6"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.logout-button">
            <Setter Property="Background" Value="#D94A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.logout-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BD3535"/>
        </Style>
        <Style Selector="Button.logout-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#992A2A"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #22000000"/>
        </Style>

        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style Selector="Separator.section">
            <Setter Property="Margin" Value="0,14,0,14"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F3F4F6" Margin="24" HorizontalAlignment="Stretch" MaxWidth="1440"
          RowDefinitions="Auto,*"
          ColumnDefinitions="*">


        <!-- Panele poniżej zakładek -->
        <Grid Grid.Row="1" ColumnDefinitions="280,24,*">
            
            <!-- Lewy panel - Zarządzanie -->
            <StackPanel Grid.Column="0" Spacing="16">
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Zarządzanie" Classes="header"/>
                        
                        <!-- Pola dla Użytkowników -->
                        <StackPanel IsVisible="{Binding IsUsersVisible}" Spacing="10">
                            <TextBox Watermark="Imię" Text="{Binding NewUserFirstName}"/>
                            <TextBox Watermark="Nazwisko" Text="{Binding NewUserLastName}"/>
                            <TextBox Watermark="ID / Numer" Text="{Binding NewUserID}"/>
                            <Button Classes="admin-button" Content="+ Dodaj użytkownika" Command="{Binding AddUserCommand}"/>
                            <Button Classes="admin-button" Content="- Usuń zaznaczonych" Command="{Binding RemoveUserCommand}"/>
                        </StackPanel>

                        <!-- Pola dla Operacji -->
                        <StackPanel IsVisible="{Binding IsOperationsVisible}" Spacing="10">
                            <TextBox Watermark="Nazwa operacji" Text="{Binding NewOperationName}"/>
                            <TextBox Watermark="Opis operacji" Text="{Binding NewOperationDescription}"/>
                            <Button Classes="admin-button" Content="+ Dodaj operację" Command="{Binding AddOperationCommand}"/>
                            <Button Classes="admin-button" Content="- Usuń zaznaczone" Command="{Binding RemoveOperationCommand}"/>
                        </StackPanel>

                        <!-- Pola dla Zleceń -->
                        <StackPanel IsVisible="{Binding IsJobsVisible}" Spacing="10">
                            <TextBox Watermark="Nazwa zlecenia" Text="{Binding NewJobName}"/>
                            <TextBox Watermark="Opis zlecenia" Text="{Binding NewJobDescription}"/>
                            <ComboBox ItemsSource="{Binding JobStatuses}" SelectedItem="{Binding NewJobStatus}" HorizontalAlignment="Stretch"/>
                            <Button Classes="admin-button" Content="Przypisz operacje" Command="{Binding PrepareAddJobCommand}"/>
                            <Button Classes="admin-button" Content="+ Dodaj zlecenie" Command="{Binding PrepareAddJobCommand}"/>
                            <Button Classes="admin-button" Content="- Usuń zaznaczone" Command="{Binding RemoveJobCommand}"/>
                        </StackPanel>

                        <Separator Classes="section"/>
                        <Button Classes="logout-button" Content="Wyloguj" Command="{Binding LogoutCommand}"/>
                    </StackPanel>
                </Border>
            </StackPanel>


            <!-- Prawy panel dynamiczny -->
            <StackPanel Grid.Column="2" Spacing="20">
                
                <!-- Podsumowania -->
                <Grid ColumnDefinitions="*,20,*,20,*">
                   <Button Grid.Column="0"
        Command="{Binding ShowUsersCommand}"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
         HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">


    <Border Classes="card"
            Background="#E3F2FD"
            Padding="16">

        <StackPanel>
            <TextBlock Text="Użytkownicy"
                       FontSize="12"
                       Foreground="#1976D2"/>

            <TextBlock Text="{Binding UserCount}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1976D2"/>
        </StackPanel>

    </Border>
</Button>
                    <Button Grid.Column="2"
        Command="{Binding ShowOperationsCommand}"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
         HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <Border Classes="card"
            Background="#F1F8E9"
            Padding="16">

        <StackPanel>
            <TextBlock Text="Operacje"
                       FontSize="12"
                       Foreground="#388E3C"/>
            <TextBlock Text="{Binding OperationCount}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#388E3C"/>
        </StackPanel>

    </Border>
</Button>
                    <Button Grid.Column="4"
        Command="{Binding ShowJobsCommand}"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
         HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <Border Classes="card"
            Background="#FFF3E0"
            Padding="16">

        <StackPanel>
            <TextBlock Text="Zlecenia"
                       FontSize="12"
                       Foreground="#F57C00"/>
            <TextBlock Text="{Binding JobCount}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#F57C00"/>
        </StackPanel>

    </Border>
</Button>
                </Grid>

                <!-- Filtrowanie i Lista -->
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Lista dynamiczna" Classes="header" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Watermark="Szukaj po nazwie lub ID..." Text="{Binding SearchQuery}" Width="300"/>
                        </Grid>

                        <ScrollViewer Height="500">
                            <StackPanel>
                                <!-- Widok Użytkowników -->
                                <StackPanel IsVisible="{Binding IsUsersVisible}">
                                    <Grid ColumnDefinitions="50,2*,2*,1*,2*,Auto" Margin="0,0,0,10">
                                        <TextBlock Grid.Column="1" Text="Imię" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="Nazwisko" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="ID" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="4" Text="Data zatrudnienia" FontWeight="Bold"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding FilteredUsers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:UserItemViewModel">
                                                <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <Grid ColumnDefinitions="50,2*,2*,1*,2*,Auto">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding FirstName}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding LastName}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Identifier}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding EmploymentDate}" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="5" Content="Usuń" Classes="logout-button" Padding="8,4" FontSize="12"
                                                                Command="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).RemoveUserCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Widok Operacji -->
                                <StackPanel IsVisible="{Binding IsOperationsVisible}">
                                    <Grid ColumnDefinitions="50,3*,5*,Auto,Auto" Margin="0,0,0,10">
                                        <TextBlock Grid.Column="1" Text="Nazwa operacji" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="Opis" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="Liczba pracowników" FontWeight="Bold"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding FilteredOperations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:OperationItemViewModel">
                                                <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <Grid ColumnDefinitions="50,3*,5*,Auto,Auto">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding OperationName}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Description}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding CurrentWorkersCount}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <Button Grid.Column="4" Content="Usuń" Classes="logout-button" Padding="8,4" FontSize="12"
                                                                Command="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).RemoveOperationCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Widok Zleceń -->
                                <StackPanel IsVisible="{Binding IsJobsVisible}">
                                    <Grid ColumnDefinitions="50,2*,4*,2*,2*,Auto" Margin="0,0,0,10">
                                        <TextBlock Grid.Column="1" Text="Nazwa zlecenia" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="Opis zlecenia" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="4" Text="Data utworzenia" FontWeight="Bold"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding FilteredJobs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:JobItemViewModel">
                                                <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <Grid ColumnDefinitions="50,2*,4*,2*,2*,Auto">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding JobName}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Description}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Status}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="5" Content="Usuń" Classes="logout-button" Padding="8,4" FontSize="12"
                                                                Command="{Binding $parent[UserControl].((vm:AdminWindowViewModel)DataContext).RemoveJobCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

        <Border Grid.ColumnSpan="3" Background="#80000000" IsVisible="{Binding IsAssignOperationsVisible}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="12" Padding="20" Width="600">
                <StackPanel Spacing="12">
                    <TextBlock Text="Przypisz operacje do zlecenia" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Wybierz operacje które mają należeć do zlecenia:"/>
                    <ScrollViewer Height="300">
                        <ItemsControl ItemsSource="{Binding AvailableOperationsForAssign}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:OperationItemViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}"/>
                                        <TextBlock Text="{Binding OperationName}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" - " VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Description}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Classes="admin-button" Content="Anuluj" Command="{Binding CancelAddJobCommand}"/>
                        <Button Classes="admin-button" Content="Zatwierdź" Command="{Binding ConfirmAddJobCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
        </Grid>
    </Grid>
</UserControl>