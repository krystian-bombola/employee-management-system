<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:employee_management_system.ViewModels"
        x:Class="employee_management_system.Views.ConfirmDeleteWindow"
        x:DataType="vm:ConfirmDeleteViewModel"
        Title="{Binding WindowTitle}"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Classes="dialog-window">

    <Border Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A1A1A"/>
            <TextBlock Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="#333"/>
            <Grid ColumnDefinitions="*,12,*">
                <Button Name="CancelButton"
                        Grid.Column="0"
                        Classes="logout-button"
                        Content="Nie"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2"
                        Classes="admin-button"
                        Content="Tak, usuń"
                        Command="{Binding ConfirmCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
