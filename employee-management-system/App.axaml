<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="employee_management_system.App"
             xmlns:local="using:employee_management_system"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://employee-management-system/Assets/Styles/Foundation.axaml"/>
        <StyleInclude Source="avares://employee-management-system/Assets/Styles/Controls.axaml"/>
        <StyleInclude Source="avares://employee-management-system/Assets/Styles/Views/AssignOperationsStyles.axaml"/>
    </Application.Styles>
</Application>
